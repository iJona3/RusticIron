---
// CTA.astro — Visual Call To Action with contact info
import TexasStar from './TexasStar.astro';

const contacts = [
  {
    type: 'WhatsApp',
    icon: '💬',
    labelEs: 'Ing. Manuel de la Peña',
    labelEn: 'Eng. Manuel de la Peña',
    value: '844 122 7872',
    href: 'https://wa.me/528441227872?text=Hola%2C%20me%20interesa%20solicitar%20información',
    color: 'var(--brick-red-light)',
  },
  {
    type: 'WhatsApp',
    icon: '💬',
    labelEs: 'Ing. Miguel Herber',
    labelEn: 'Eng. Miguel Herber',
    value: '844 102 0928',
    href: 'https://wa.me/528441020928?text=Hola%2C%20me%20interesa%20solicitar%20información',
    color: 'var(--brick-red-light)',
  },
  {
    type: 'Email',
    icon: '✉️',
    labelEs: 'Ventas',
    labelEn: 'Sales',
    value: 'ventas@rusticironmexico.com',
    href: 'mailto:ventas@rusticironmexico.com',
    color: 'var(--saddle-brown-light)',
  },
  {
    type: 'Email',
    icon: '✉️',
    labelEs: 'Dirección',
    labelEn: 'Management',
    value: 'direccion@rusticironmexico.com',
    href: 'mailto:direccion@rusticironmexico.com',
    color: 'var(--saddle-brown-light)',
  },
];
---

<section id="contacto" class="relative py-24 md:py-36 overflow-hidden"
  style="background: linear-gradient(160deg, var(--iron-950) 0%, var(--iron-900) 50%, var(--iron-950) 100%);">

  <!-- Decorative blurs -->
  <div class="mesh-bloom animate-pulse-glow"
    style="width:600px; height:600px; top:-10%; left:-15%; background: radial-gradient(circle, rgba(178,63,47,0.14) 0%, transparent 70%);"></div>
  <div class="mesh-bloom animate-pulse-glow"
    style="width:500px; height:500px; bottom:-10%; right:-10%; background: radial-gradient(circle, rgba(140,82,48,0.12) 0%, transparent 70%); animation-delay: 2.5s;"></div>

  <!-- Top wave -->
  <div class="wave-top" style="margin-top: -1px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:80px;">
      <path d="M0,20 C480,80 960,0 1440,40 L1440,0 L0,0 Z" fill="#0a0909"/>
    </svg>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- Main card (leather-card) -->
    <div class="leather-card rounded-3xl p-10 md:p-16 text-center reveal"
      style="box-shadow: 0 40px 100px rgba(0,0,0,0.7), 0 0 80px rgba(178,63,47,0.1);">
      <!-- Grain texture overlay -->
      <div class="grain-overlay"></div>

      <!-- Label -->
      <span class="section-label mb-6 inline-flex">
        <TexasStar class="text-brick-red-light" size="w-4 h-4" />
        <span data-es="Contacto Directo" data-en="Direct Contact">Contacto Directo</span>
      </span>

      <!-- Headline -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 mt-4 leading-tight"
        style="font-family: var(--font-title);"
        data-es="¿Listo para optimizar<br/><span class='gradient-text-gold'>tu producción?</span>"
        data-en="Ready to optimize<br/><span class='gradient-text-gold'>your production?</span>">
        ¿Listo para optimizar<br/>
        <span class="gradient-text-gold">tu producción?</span>
      </h2>

      <p class="text-lg max-w-xl mx-auto mb-10 font-body" style="color: var(--steel-400);"
        data-es="Cotiza hoy mismo. Contamos con stock disponible para <strong style='color: var(--steel-100);'>entregas urgentes directas en planta</strong>."
        data-en="Get a quote today. We have stock available for <strong style='color: var(--steel-100);'>urgent direct-to-plant deliveries</strong>.">
        Cotiza hoy mismo. Contamos con stock disponible para
        <strong style="color: var(--steel-100);">entregas urgentes directas en planta</strong>.
      </p>

      <!-- Contact Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 relative z-10">
        {contacts.map((c, i) => (
          <a href={c.href}
            target={c.type === 'WhatsApp' ? '_blank' : undefined}
            rel={c.type === 'WhatsApp' ? 'noopener noreferrer' : undefined}
            class="group flex items-center gap-4 p-5 rounded-2xl text-left transition-all duration-300 reveal"
            style={`
              background: rgba(10, 9, 9, 0.45);
              border: 1px solid rgba(140,82,48,0.22);
              transition-delay: ${i * 80}ms;
            `}>
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0 transition-all duration-300 group-hover:scale-110"
              style={`background: ${c.color}12; border: 1px solid ${c.color}25; color: ${c.color};`}>
              {c.icon}
            </div>
            <!-- Info -->
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase mb-0.5 font-subtitle" style={`color: ${c.color};`}>{c.type}</p>
              <p class="text-xs mb-1 font-body" style="color: var(--steel-400);"
                data-es={c.labelEs} data-en={c.labelEn}>{c.labelEs}</p>
              <p class="text-sm font-bold truncate group-hover:underline font-body" style="color: var(--steel-100);">{c.value}</p>
            </div>
            <!-- Arrow -->
            <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-300 group-hover:translate-x-1 ml-auto" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--steel-500);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Main WhatsApp CTA -->
      <div class="flex flex-wrap justify-center gap-4 mb-8 relative z-10">
        <a href="https://wa.me/528441227872?text=Hola%2C%20quiero%20cotizar%20un%20pedido"
          target="_blank" rel="noopener noreferrer"
          class="btn-gold text-base px-10 py-4">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span data-es="Solicitar Cotización Ahora" data-en="Request Quote Now">Solicitar Cotización Ahora</span>
        </a>
      </div>

      <!-- Address -->
      <div class="flex items-center justify-center gap-2 text-sm reveal font-body relative z-10" style="color: var(--steel-400);">
        <svg class="w-4 h-4 flex-shrink-0 text-brick-red-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span data-es="Av. Los Nogales 415, Col. Los Nogales II, CP 25057, Saltillo, Coahuila, MX." data-en="415 Los Nogales Ave, Los Nogales II, CP 25057, Saltillo, Coahuila, MX.">Av. Los Nogales 415, Col. Los Nogales II, CP 25057, Saltillo, Coahuila, MX.</span>
      </div>
    </div>
  </div>
</section>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.07 });
  revealEls.forEach(el => observer.observe(el));
</script>
