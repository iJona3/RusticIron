  /* Tooltip show helper class */
  #product-tooltip.show {
    opacity: 1;
  }

  /* Hotspot focus ring */
  .hotspot-overlay:focus {
    outline: none;
  }
  .hotspot-overlay:focus .absolute {
    border-color: var(--brick-red-light) !important;
    background: rgba(178, 63, 47, 0.08) !important;
  }

  /* Custom styling for horizontal scroll hint */
  .scroll-hint-container::-webkit-scrollbar {
    height: 5px;
  }
  .scroll-hint-container::-webkit-scrollbar-track {
    background: rgba(140, 82, 48, 0.03);
    border-radius: 9px;
  }
  .scroll-hint-container::-webkit-scrollbar-thumb {
    background: rgba(178, 63, 47, 0.25);
    border-radius: 9px;
  }
</style>

<script>
  // ── Scroll Reveal System ──
  const revealEls = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.06 });
  revealEls.forEach(el => revealObserver.observe(el));

  // ── Tooltip and Click-to-WhatsApp Hotspot Logic ──
  const tooltip = document.getElementById('product-tooltip')!;

  document.querySelectorAll('[data-hotspot]').forEach(hotspot => {
    // Show Tooltip on enter
    hotspot.addEventListener('mouseenter', () => {
      const lang = localStorage.getItem('lang') || 'es';
      const nameEs = hotspot.getAttribute('data-name-es')!;
      const nameEn = hotspot.getAttribute('data-name-en')!;
      
      tooltip.textContent = lang === 'es' ? nameEs : nameEn;
      tooltip.classList.add('show');
    });

    // Hide Tooltip on leave
    hotspot.addEventListener('mouseleave', () => {
      tooltip.classList.remove('show');
    });

    // Follow cursor
    hotspot.addEventListener('mousemove', e => {
      const ev = e as MouseEvent;
      tooltip.style.left = `${ev.clientX + 15}px`;
      tooltip.style.top = `${ev.clientY + 15}px`;
    });

    // Click handler to open WhatsApp with prefilled message
    hotspot.addEventListener('click', e => {
      e.preventDefault();
      const lang = localStorage.getItem('lang') || 'es';
      const nameEs = hotspot.getAttribute('data-name-es')!;
      const nameEn = hotspot.getAttribute('data-name-en')!;
      const catEs = hotspot.getAttribute('data-slide-title-es')!;
      const catEn = hotspot.getAttribute('data-slide-title-en')!;

      const productName = lang === 'es' ? nameEs : nameEn;
      const categoryName = lang === 'es' ? catEs : catEn;

      const msg = lang === 'es'
        ? `Hola, me interesa solicitar cotización y más información sobre el producto: *${productName}* de la categoría *${categoryName}*.`
        : `Hello, I'm interested in requesting a quote and more information about: *${productName}* from the category *${categoryName}*.`;

      const waUrl = `https://wa.me/528441227872?text=${encodeURIComponent(msg)}`;
      window.open(waUrl, '_blank', 'noopener,noreferrer');
    });
  });
</script>
