    color: '#ab6a42', // saddle brown light
    images: [
      { src: '/images/Máquinas de coser — Juki, Durkopp, Pegaso/juki_recta.jpg', alt: 'Máquina de coser Juki recta industrial' },
      { src: '/images/Máquinas de coser — Juki, Durkopp, Pegaso/about-product_3.webp', alt: 'Máquina de coser industrial' },
