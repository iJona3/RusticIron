---

<!-- ── Stacked Independent Sections Layout ── -->
{slides.map((slide, sIdx) => (
  <section id={slide.id} class="relative py-24 md:py-32 overflow-hidden border-b border-saddle-brown/10 reveal"
    style={`background: ${slide.bg};`}>

    <!-- Decorative blobs for each section -->
    <div class="mesh-bloom"
      style={`width:600px; height:600px; ${sIdx % 2 === 0 ? 'right:-10%; top:5%;' : 'left:-8%; bottom:10%;'} background: radial-gradient(circle, rgba(140,82,48,0.06) 0%, transparent 70%);`}></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section Title & Description -->
      <div class="text-center mb-8 max-w-3xl mx-auto">
        <span class="section-label mb-4 inline-flex">
          <TexasStar class="text-brick-red-light" size="w-3.5 h-3.5" />
          <span data-es={`Categoría de Insumos ${slide.num}`} data-en={`Supplies Category ${slide.num}`}>Categoría de Insumos {slide.num}</span>
        </span>
        
        <h2 class="text-3xl md:text-5xl font-bold uppercase tracking-wider font-title mt-3 mb-5" 
          style="color: var(--iron-950); line-height: 1.15;"
          data-es={slide.titleEs} 
          data-en={slide.titleEn}>
          {slide.titleEs}
        </h2>
        
        <p class="text-base md:text-lg font-body leading-relaxed max-w-2xl mx-auto" style="color: var(--iron-700);"
          data-es={slide.descEs} 
          data-en={slide.descEn}>
          {slide.descEs}
        </p>
      </div>

      <!-- Large Interactive Slide Card Showcase -->
      <div class="relative w-full max-w-5xl mx-auto rounded-2xl overflow-hidden shadow-2xl border border-saddle-brown/20 bg-white select-none relative-slide-container">
        <div class="grain-overlay"></div>
        
        <!-- Slide Image -->
        <img
          src={slide.image}
          alt={slide.titleEs}
          class="w-full h-auto object-contain block"
          loading="lazy"
          decoding="async"
        />

        <!-- Interactive Hotspots Grid Overlay -->
        <div class="absolute inset-0 z-10 w-full h-full pointer-events-none">
          {slide.hotspots.map((hotspot) => (
            <a
              href="#"
              class="absolute pointer-events-auto transition-all duration-200 hotspot-overlay group/hotspot"
              style={`top: ${hotspot.top}; left: ${hotspot.left}; width: ${hotspot.width}; height: ${hotspot.height};`}
              data-hotspot
              data-name-es={hotspot.nameEs}
              data-name-en={hotspot.nameEn}
              data-slide-title-es={slide.titleEs}
              data-slide-title-en={slide.titleEn}
              aria-label={`Inquire about ${hotspot.nameEn}`}
            >
              <!-- Glowing border box that activates on hover -->
              <div class="absolute inset-0 rounded border-2 border-dashed border-transparent transition-all duration-300 group-hover/hotspot:border-brick-red-light group-hover/hotspot:bg-brick-red-light/8 group-hover/hotspot:shadow-[0_0_20px_rgba(178,63,47,0.35)]"></div>

              <!-- Pulsing Interactive Indicator Dot (for touch/mobile visibility) -->
              <div class="absolute w-5 h-5 flex items-center justify-center pointer-events-none" 
                style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <!-- Ping outer ring -->
                <span class="absolute inline-flex h-full w-full rounded-full bg-brick-red-light/35 animate-ping"></span>
                <!-- Solid inner dot -->
                <span class="relative inline-flex rounded-full h-2 w-2 bg-brick-red-light/85 shadow-[0_0_6px_rgba(178,63,47,0.5)]"></span>
              </div>
            </a>
          ))}
        </div>

      </div>

      <!-- Tiny note under card -->
      <div class="text-center mt-3">
        <p class="text-xs font-subtitle uppercase tracking-widest text-iron-500"
          data-es="Haz clic sobre cualquier producto de la imagen para cotizar"
          data-en="Click on any product in the image to inquire">
          Haz clic sobre cualquier producto de la imagen para cotizar
        </p>
      </div>

    </div>
  </section>
))}

<!-- ── Special Supply Request / CTA Section ── -->
<section class="relative py-20 overflow-hidden" style="background: var(--parchment-light);">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="parchment-card p-10 border border-saddle-brown/20 relative overflow-hidden shadow-lg">
      <div class="grain-overlay"></div>
      <TexasStar class="text-brick-red mx-auto mb-4 animate-spin-slow" size="w-7 h-7" />
      <h3 class="text-xl md:text-2xl font-bold uppercase tracking-wider font-subtitle mb-4" style="color: var(--brick-red-dark);"
        data-es="¿Buscas algún repuesto o maquinaria especial?" data-en="Looking for a special spare part or machinery?">
        ¿Buscas algún repuesto o maquinaria especial?
      </h3>
      <p class="text-sm md:text-base leading-relaxed mb-8 font-body text-iron-700"
        data-es="Disponemos de un amplio catálogo de refacciones originales y genéricas importadas directamente de fabricantes líderes en Europa y Asia."
        data-en="We have a wide catalog of original and generic spare parts imported directly from leading manufacturers in Europe and Asia.">
        Disponemos de un amplio catálogo de refacciones originales y genéricas importadas directamente de fabricantes líderes en Europa y Asia.
      </p>
      <a href="https://wa.me/528441227872?text=Hola%2C%20busco%20un%20producto%20específico"
        target="_blank" rel="noopener noreferrer"
        class="btn-gold text-xs px-6 py-3">
        <span data-es="Consultar Catálogo Completo" data-en="Consult Full Catalog">Consultar Catálogo Completo</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- ── Floating Custom Product Tooltip ── -->
<div id="product-tooltip" class="fixed pointer-events-none z-[150] px-3.5 py-2 rounded-xl text-xs font-bold font-subtitle text-white bg-iron-950/95 border border-saddle-brown/35 shadow-2xl opacity-0 transition-opacity duration-200"
  style="backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">
