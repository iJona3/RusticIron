      { src: '/images/Tijeras, Nippers y Descosedores/62FA8A81-BCB6-4023-BBE8-272AFB17D063.webp', alt: 'Tijeras industriales para textil' },
      { src: '/images/Tijeras, Nippers y Descosedores/tijeras-industriales-textil-pollerias-11-truper-ajustables-102945.jpg', alt: 'Tijeras ajustables industriales' },
