---
// Products.astro — Premium Product Gallery with Real Images + Detailed Product Modal (Bilingual Support)
import TexasStar from './TexasStar.astro';

const categories = [
  {
    id: 'maquinas-coser',
    icon: '🧵',
    titleEs: 'Máquinas de Coser',
    titleEn: 'Sewing Machines',
    subtitleEs: 'Juki · Dürkopp · Pegaso',
    subtitleEn: 'Juki · Dürkopp · Pegaso',
