    ],
    featured: false,
  },
  {
    id: 'agujas',
    icon: '🪡',
    titleEs: 'Agujas Industriales',
    titleEn: 'Industrial Needles',
    subtitleEs: 'Organ · Groz-Beckert · Schmetz',
    subtitleEn: 'Organ · Groz-Beckert · Schmetz',
    descEs: 'Agujas de precisión de las tres marcas líderes globales. Para costura industrial de todo tipo y calibre.',
    descEn: 'Precision needles from the three global leading brands. For industrial sewing of all types and gauges.',
    color: '#decbb7', // sand
    images: [
      { src: '/images/Agujas — Organ, Groz-Beckert, Schmetz/Groz-scaled.jpg', alt: 'Agujas Groz-Beckert industriales' },
      { src: '/images/Agujas — Organ, Groz-Beckert, Schmetz/Sewing_Gestaltungsbilder_Kundenportal_Startseite.jpg', alt: 'Agujas para máquina de coser industrial' },
