  { name: 'Tetakawi', color: '#0e7490',
    svg: `<svg viewBox="0 0 110 36" xmlns="http://www.w3.org/2000/svg"><polygon points="12,30 4,30 8,12" fill="#0e7490" opacity="0.8"/><polygon points="18,30 12,30 15,18" fill="#0891b2"/><polygon points="24,30 18,30 21,6" fill="#06b6d4"/><text x="68" y="26" font-family="Arial,sans-serif" font-size="14" font-weight="300" fill="#0e7490" text-anchor="middle" letter-spacing="1">tetakawi</text></svg>` },
  { name: 'Imp. Dinámicas', color: '#1d4ed8',
    svg: `<svg viewBox="0 0 110 36" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="18" r="12" fill="none" stroke="#1d4ed8" stroke-width="1.5"/><ellipse cx="14" cy="18" rx="6" ry="12" fill="none" stroke="#1d4ed8" stroke-width="1"/><line x1="2" y1="18" x2="26" y2="18" stroke="#1d4ed8" stroke-width="1"/><text x="68" y="16" font-family="Arial Black,sans-serif" font-size="7" font-weight="900" fill="#1d4ed8" text-anchor="middle">IMPORTACIONES</text><text x="68" y="28" font-family="Arial Black,sans-serif" font-size="7" font-weight="900" fill="#1d4ed8" text-anchor="middle">DINÁMICAS</text></svg>` },
