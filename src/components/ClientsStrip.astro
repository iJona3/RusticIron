---
// ClientsStrip.astro — Double-row infinite marquee with embedded SVG logos
import BarbedWire from './BarbedWire.astro';

const allClients = [
  { name: 'Global Jeonjin Mexico', logoType: 'img', src: '/logos/globaljeojin.png' },
  { name: 'CVG', logoType: 'img', src: '/logos/cvg.png' },
  { name: 'Kolon Industries', logoType: 'img', src: '/logos/kolon.png' },
  { name: 'HNI', logoType: 'img', src: '/logos/hni.png' },
  { name: 'Faurecia', logoType: 'img', src: '/logos/faurencia.png' },
  { name: 'Novalink', logoType: 'img', src: '/logos/novalink.png' },
  { name: 'Vuteq Industries', logoType: 'svg',
    svg: `<svg viewBox="0 0 110 36" xmlns="http://www.w3.org/2000/svg"><text x="55" y="24" font-family="Arial Black,sans-serif" font-size="16" font-weight="900" fill="#1e3a5f" text-anchor="middle" letter-spacing="1">VUTEQ</text></svg>` },
  { name: 'Tachi-S', logoType: 'img', src: '/logos/tachis.png' },
  { name: 'Daimay Automotive', logoType: 'img', src: '/logos/daimay.png' },
  { name: 'NYX México Plastics', logoType: 'img', src: '/logos/nyx.png' },
  { name: 'Outer Armor', logoType: 'img', src: '/logos/outer.png' },
  { name: 'Blinds To Go', logoType: 'img', src: '/logos/blinds.png' },
  { name: 'ErsaFlex', logoType: 'img', src: '/logos/erasaflex.png' },
  { name: 'Entrada Group', logoType: 'img', src: '/logos/entrada.png' },
  { name: 'Grupo Antolín', logoType: 'img', src: '/logos/grupoantolin.png' },
  { name: 'SK SeatKing', logoType: 'img', src: '/logos/seat.png' },
  { name: 'Tetakawi', logoType: 'img', src: '/logos/tetakawi.png' },
  { name: 'Imp. Dinámicas', logoType: 'img', src: '/logos/dinamicas.png' },
  { name: 'Yanfeng Automotive', logoType: 'img', src: '/logos/yanfeng.png' },
  { name: 'IMMI', logoType: 'img', src: '/logos/immi.png' },
  { name: 'Palliser', logoType: 'svg',
    svg: `<svg viewBox="0 0 110 36" xmlns="http://www.w3.org/2000/svg"><text x="55" y="26" font-family="Arial Black,sans-serif" font-size="18" font-weight="900" fill="#cc2222" text-anchor="middle" letter-spacing="1">PALLISER</text></svg>` },
];

// Split into two rows dynamically
const half = Math.ceil(allClients.length / 2);
const row1 = allClients.slice(0, half);
const row2 = allClients.slice(half);
---

<div class="relative z-10 px-4" style="margin-top: -40px;">
  <div class="max-w-7xl mx-auto">
    <div class="relative rounded-2xl py-6 px-5 overflow-hidden marquee-wrapper"
      style="background:rgba(255, 255, 255, 0.85); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border:1px solid rgba(140,82,48,0.18); box-shadow:0 20px 60px rgba(86,48,26,0.06);">

      <!-- Grain overlay -->
      <div class="grain-overlay"></div>

      <!-- Top fence barbed wire -->
      <BarbedWire class="text-saddle-brown/20 -mt-2 mb-2" />

      <!-- Label -->
      <div class="flex items-center gap-4 mb-5">
        <div class="h-px flex-1" style="background:linear-gradient(90deg,transparent,rgba(140,82,48,0.3),transparent);"></div>
        <p class="text-xs font-bold tracking-[0.25em] uppercase whitespace-nowrap font-subtitle" style="color:var(--saddle-brown-dark);"
          data-es="Empresas que confían en nosotros" data-en="Companies that trust us">
          Empresas que confían en nosotros
        </p>
        <div class="h-px flex-1" style="background:linear-gradient(90deg,transparent,rgba(140,82,48,0.3),transparent);"></div>
      </div>

      <!-- ROW 1 → left to right -->
      <div class="relative overflow-hidden mb-4">
        <div class="absolute left-0 top-0 bottom-0 w-16 z-10 pointer-events-none"
          style="background:linear-gradient(to right,#fbf8f0,transparent); opacity: 0.85;"></div>
        <div class="absolute right-0 top-0 bottom-0 w-16 z-10 pointer-events-none"
          style="background:linear-gradient(to left,#fbf8f0,transparent); opacity: 0.85;"></div>

        <div class="flex gap-4 w-max items-center strip-marquee-r1">
          {[...row1, ...row1].map((c) => (
            <div class="strip-card flex items-center gap-2.5 flex-shrink-0 px-3.5 py-2.5 rounded-xl"
              style="background:rgba(140, 82, 48, 0.03); border:1px solid rgba(140, 82, 48, 0.08);">
              {c.logoType === 'img' ? (
                <div class="flex-shrink-0 flex items-center justify-center" style="width:70px;height:32px;">
                  <img src={c.src} alt={c.name} class="max-w-full max-h-full object-contain" />
                </div>
              ) : (
                <div class="flex-shrink-0" style="width:70px;height:32px;" set:html={c.svg} />
              )}
              <span class="text-xs font-semibold whitespace-nowrap tracking-wide" style="color: var(--iron-800); font-family: system-ui, -apple-system, sans-serif;">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- ROW 2 → right to left -->
      <div class="relative overflow-hidden mb-2">
        <div class="absolute left-0 top-0 bottom-0 w-16 z-10 pointer-events-none"
          style="background:linear-gradient(to right,#fbf8f0,transparent); opacity: 0.85;"></div>
        <div class="absolute right-0 top-0 bottom-0 w-16 z-10 pointer-events-none"
          style="background:linear-gradient(to left,#fbf8f0,transparent); opacity: 0.85;"></div>

        <div class="flex gap-4 w-max items-center strip-marquee-r2">
          {[...row2, ...row2].map((c) => (
            <div class="strip-card flex items-center gap-2.5 flex-shrink-0 px-3.5 py-2.5 rounded-xl"
              style="background:rgba(140, 82, 48, 0.03); border:1px solid rgba(140, 82, 48, 0.08);">
              {c.logoType === 'img' ? (
                <div class="flex-shrink-0 flex items-center justify-center" style="width:70px;height:32px;">
                  <img src={c.src} alt={c.name} class="max-w-full max-h-full object-contain" />
                </div>
              ) : (
                <div class="flex-shrink-0" style="width:70px;height:32px;" set:html={c.svg} />
              )}
              <span class="text-xs font-semibold whitespace-nowrap tracking-wide" style="color: var(--iron-800); font-family: system-ui, -apple-system, sans-serif;">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Bottom fence barbed wire -->
      <BarbedWire class="text-saddle-brown/20 mt-4 -mb-2" />
      
    </div>
  </div>
</div>

<style>
  /* Strip card logos — original colors with soft opacity transition */
  .strip-card img, .strip-card svg {
    width: 100%;
    height: 100%;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }
  .strip-card:hover img, .strip-card:hover svg {
    opacity: 1;
  }

  /* Row 1: left → right */
  .strip-marquee-r1 { animation: marquee 38s linear infinite; }
  /* Row 2: right → left */
  .strip-marquee-r2 { animation: marquee-rev 30s linear infinite; }

  @keyframes marquee-rev {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Pause both rows on hover of the wrapper */
  .marquee-wrapper:hover .strip-marquee-r1,
  .marquee-wrapper:hover .strip-marquee-r2 {
    animation-play-state: paused;
  }
</style>
