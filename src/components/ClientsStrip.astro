    svg: `<svg viewBox="0 0 120 36" xmlns="http://www.w3.org/2000/svg"><path d="M6,6 L12,6 L16,16 L20,6 L26,6 L19,22 L19,32 L13,32 L13,22 Z" fill="#1d4ed8"/><text x="74" y="19" font-family="Arial,sans-serif" font-size="13" font-weight="700" fill="#1d4ed8" text-anchor="middle">Yanfeng</text><text x="74" y="31" font-family="Arial,sans-serif" font-size="6" fill="#64748b" text-anchor="middle">Automotive Interiors</text></svg>` },
