---
// Footer.astro — Contact and Brand Footer (Identical to user slide layout)
import BarbedWire from './BarbedWire.astro';
import TexasStar from './TexasStar.astro';

const currentYear = new Date().getFullYear();
---

<footer id="contacto" class="relative overflow-hidden pt-20 pb-8" style="background: var(--parchment); border-top: 1px solid rgba(140,82,48,0.18);">

  <!-- Top border with Barbed Wire -->
  <div class="mb-12">
    <BarbedWire class="text-saddle-brown/30" />
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- ── Contact grid matching slide layout ── -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 pb-12 border-b border-saddle-brown/20">
      
      <!-- ── Left Column: Email & Dirección (md:col-span-6) ── -->
      <div class="lg:col-span-6 flex flex-col gap-10">
        
        <!-- Section Title -->
        <div>
          <h2 class="text-4xl md:text-5xl font-bold uppercase tracking-wider font-title" style="color: var(--iron-950);"
            data-es="Contacto" data-en="Contact">
            Contacto
          </h2>
        </div>

        <!-- Emails Section -->
        <div class="flex items-start gap-4">
          <!-- Email Blue Icon -->
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 bg-blue-500/10 border border-blue-500/20 text-blue-500 shadow-md">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold font-subtitle mb-2" style="color: var(--iron-950);">Email:</h3>
            <ul class="space-y-1 text-sm font-body">
              <li>
                <a href="mailto:contacto@rusticironmexico.com" class="hover:underline transition-colors text-iron-700 hover:text-brick-red-light font-medium">
                  contacto@rusticironmexico.com
                </a>
              </li>
              <li>
                <a href="mailto:direccion@rusticironmexico.com" class="hover:underline transition-colors text-iron-700 hover:text-brick-red-light font-medium">
                  direccion@rusticironmexico.com
                </a>
              </li>
              <li>
                <a href="mailto:ventas@rusticironmexico.com" class="hover:underline transition-colors text-iron-700 hover:text-brick-red-light font-medium">
                  ventas@rusticironmexico.com
                </a>
              </li>
              <li>
                <a href="mailto:admon@rusticironmexico.com" class="hover:underline transition-colors text-iron-700 hover:text-brick-red-light font-medium">
                  admon@rusticironmexico.com
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Dirección Section -->
        <div class="flex items-start gap-4">
          <!-- Compass Maps Icon -->
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 bg-red-500/10 border border-red-500/20 text-red-500 shadow-md">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold font-subtitle mb-2" style="color: var(--iron-950);"
              data-es="Dirección:" data-en="Address:">Dirección:</h3>
            <p class="text-sm font-body leading-relaxed max-w-sm text-iron-700">
              Avenida Los Nogales 415 Col. Los Nogales II,<br/>
              CP 25057, Saltillo, Coahuila, MX.
            </p>
          </div>
        </div>

      </div>

      <!-- ── Right Column: WhatsApp, Teams & Brand Logos (md:col-span-6) ── -->
      <div class="lg:col-span-6 flex flex-col justify-between gap-10">
        
        <!-- WhatsApp Contacts -->
        <div class="flex items-start gap-4">
          <!-- WhatsApp Green Icon -->
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 bg-green-500/10 border border-green-500/20 text-green-500 shadow-md">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="w-full">
            <h3 class="text-lg font-bold font-subtitle mb-3" style="color: var(--iron-950);">WhatsApp:</h3>
            
            <!-- Sales -->
            <div class="mb-4">
              <h4 class="text-xs font-bold font-subtitle uppercase tracking-wider mb-2 text-saddle-brown-dark"
                data-es="Contacto y Ventas" data-en="Contact & Sales">CONTACTO Y VENTAS</h4>
              <ul class="space-y-1.5 text-sm font-body">
                <li class="flex items-center justify-between gap-4 max-w-sm border-b border-saddle-brown/10 pb-1">
                  <span class="text-iron-700">Ing. Manuel de la Peña</span>
                  <a href="https://wa.me/528441020928?text=Hola%20Ing.%20Manuel%2C%20me%20interesa%20solicitar%20información%20sobre%20un%20producto"
                    target="_blank" rel="noopener noreferrer" class="font-bold hover:text-brick-red transition-colors text-iron-950">
                    844 122 7872
                  </a>
                </li>
                <li class="flex items-center justify-between gap-4 max-w-sm border-b border-saddle-brown/10 pb-1">
                  <span class="text-iron-700">Ing. Miguel Herber</span>
                  <a href="https://wa.me/528441020928?text=Hola%20Ing.%20Miguel%2C%20me%20interesa%20solicitar%20información%20sobre%20un%20producto"
                    target="_blank" rel="noopener noreferrer" class="font-bold hover:text-brick-red transition-colors text-iron-950">
                    844 102 0928
                  </a>
                </li>
              </ul>
            </div>

            <!-- Admin -->
            <div>
              <h4 class="text-xs font-bold font-subtitle uppercase tracking-wider mb-2 text-saddle-brown-dark"
                data-es="Administración" data-en="Administration">ADMINISTRACION</h4>
              <ul class="space-y-1.5 text-sm font-body">
                <li class="flex items-center justify-between gap-4 max-w-sm border-b border-saddle-brown/10 pb-1">
                  <span class="text-iron-700">Lic. Elia Cuevas B.</span>
                  <a href="https://wa.me/528441020928?text=Hola%20Lic.%20Elia%2C%20me%20interesa%20solicitar%20información%20sobre%20un%20producto"
                    target="_blank" rel="noopener noreferrer" class="font-bold hover:text-brick-red transition-colors text-iron-950">
                    844 179 5365
                  </a>
                </li>
                <li class="flex items-center justify-between gap-4 max-w-sm border-b border-saddle-brown/10 pb-1">
                  <span class="text-iron-700">Lic. Valeria Castañuela</span>
                  <a href="https://wa.me/528441020928?text=Hola%20Lic.%20Valeria%2C%20me%20interesa%20solicitar%20información%20sobre%20un%20producto"
                    target="_blank" rel="noopener noreferrer" class="font-bold hover:text-brick-red transition-colors text-iron-950">
                    844 540 8881
                  </a>
                </li>
              </ul>
            </div>

          </div>
        </div>

        <!-- Star Logo & Delivery Runner Row -->
        <div class="flex items-center justify-center lg:justify-end gap-6 mt-4 select-none">
          <img
            src="/logo2.png"
            alt="Rustic Iron Mexico"
            class="h-16 md:h-20 w-auto object-contain"
            style="filter: drop-shadow(0 2px 8px rgba(86,48,26,0.1));"
          />
          <img
            src="/imagen mensajeria azul.png"
            alt="Entrega Inmediata"
            class="h-12 md:h-16 w-auto object-contain"
            style="filter: drop-shadow(0 2px 8px rgba(0,0,0,0.06));"
          />
        </div>

      </div>

    </div>

    <!-- ── Red Stock Announcement Banner ── -->
    <div class="text-center py-6 mt-8">
      <p class="text-base md:text-lg font-black tracking-wide font-subtitle uppercase text-brick-red-light leading-snug"
        data-es="Contamos con material en stock para poder hacer entregas urgentes directas en tu planta"
        data-en="We have stock available for urgent direct-to-plant deliveries">
        Contamos con material en stock para poder hacer entregas urgentes directas en tu planta
      </p>
    </div>

    <!-- ── Sub-footer Bar ── -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 mt-4 border-t border-saddle-brown/15 text-xs font-body" style="color: var(--iron-600);">
      <div class="flex items-center gap-1.5 hover:text-brick-red transition-colors">
        <TexasStar class="text-brick-red" size="w-3.5 h-3.5" />
        <a href="https://rusticironmexico.com" class="font-bold tracking-wider font-subtitle">Rustic Iron Mexico.com</a>
      </div>
      <div>
        <p>Copyright © {currentYear} Rustic Iron Mexico. Todos los derechos reservados.</p>
      </div>
      <div>
        <a href="mailto:ventas@rusticironmexico.com" class="hover:underline hover:text-brick-red transition-colors">ventas@rusticironmexico.com</a>
      </div>
    </div>

  </div>

</footer>
