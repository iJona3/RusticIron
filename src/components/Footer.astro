---
// Footer.astro — Elegant minimal footer
import BarbedWire from './BarbedWire.astro';

const currentYear = new Date().getFullYear();const navLinks = [
  { href: '#hero',      labelEs: 'Inicio',    labelEn: 'Home' },
  { href: '#productos', labelEs: 'Productos', labelEn: 'Products' },
  { href: '#nosotros',  labelEs: 'Nosotros',  labelEn: 'About Us' },
  { href: '#clientes',  labelEs: 'Clientes',  labelEn: 'Clients' },
  { href: '#contacto',  labelEs: 'Contacto',  labelEn: 'Contact' },
];

const emailLinks = [
  { labelEs: 'Dirección',      labelEn: 'Management',     href: 'mailto:direccion@rusticironmexico.com', email: 'direccion@rusticironmexico.com' },
  { labelEs: 'Administración', labelEn: 'Administration', href: 'mailto:admon@rusticironmexico.com',     email: 'admon@rusticironmexico.com' },
  { labelEs: 'Ventas',         labelEn: 'Sales',          href: 'mailto:ventas@rusticironmexico.com',    email: 'ventas@rusticironmexico.com' },
  { labelEs: 'Contacto',       labelEn: 'Contact',        href: 'mailto:contacto@rusticironmexico.com',  email: 'contacto@rusticironmexico.com' },
];
---

<footer class="relative overflow-hidden" style="background: var(--iron-950);">

  <!-- Top border with Barbed Wire -->
  <BarbedWire class="text-saddle-brown/25" />

  <!-- Deco -->
  <div class="mesh-bloom"
    style="width:400px; height:400px; bottom:-20%; right:-10%; background: radial-gradient(circle, rgba(140,82,48,0.08) 0%, transparent 70%);"></div>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <div class="mb-6">
          <img
            src="/images/24.png"
            alt="Rustic Iron Mexico"
            style="
              height: 56px;
              width: auto;
              max-width: 200px;
              filter: invert(1) brightness(1.05) drop-shadow(0 0 12px rgba(178,63,47,0.2));
            "
          />
        </div>

        <p class="text-sm leading-relaxed mb-6 max-w-sm font-body" style="color: var(--steel-400);"
          data-es="Empresa 100% mexicana dedicada a la comercialización y distribución de productos para la industria textil. Distribuidores exclusivos de las mejores marcas mundiales."
          data-en="100% Mexican company dedicated to the marketing and distribution of products for the textile industry. Exclusive distributors of the best global brands.">
          Empresa 100% mexicana dedicada a la comercialización y distribución de productos
          para la industria textil. Distribuidores exclusivos de las mejores marcas mundiales.
        </p>

        <!-- Address -->
        <div class="flex items-start gap-3 text-sm font-body" style="color: var(--steel-500);">
          <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-brick-red-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span data-es="Av. Los Nogales 415, Col. Los Nogales II,<br/>CP 25057, Saltillo, Coahuila, MX." data-en="415 Los Nogales Ave, Los Nogales II,<br/>CP 25057, Saltillo, Coahuila, MX.">Av. Los Nogales 415, Col. Los Nogales II,<br/>CP 25057, Saltillo, Coahuila, MX.</span>
        </div>
      </div>

      <!-- Navigation Column -->
      <div>
        <h3 class="text-xs font-bold tracking-[0.2em] uppercase mb-5 font-subtitle" style="color: var(--brick-red-light);"
          data-es="Navegación" data-en="Navigation">Navegación</h3>
        <ul class="space-y-2.5">
          {navLinks.map(link => (
            <li>
              <a href={link.href}
                class="text-sm transition-all duration-200 hover:pl-2 block font-body"
                style="color: var(--steel-400);"
                onmouseover="this.style.color='var(--sand)'"
                onmouseout="this.style.color='var(--steel-400)'"
                data-es={link.labelEs} data-en={link.labelEn}>
                {link.labelEs}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-xs font-bold tracking-[0.2em] uppercase mb-5 font-subtitle" style="color: var(--brick-red-light);"
          data-es="Contacto" data-en="Contact">Contacto</h3>
        <ul class="space-y-2.5 mb-5">
          {emailLinks.map(e => (
            <li>
              <a href={e.href}
                class="text-xs transition-all duration-200 block font-body"
                style="color: var(--steel-400);"
                onmouseover="this.style.color='var(--sand)'"
                onmouseout="this.style.color='var(--steel-400)'">
                <span class="block text-[9px] uppercase tracking-widest mb-0.5 font-subtitle" style="color: var(--saddle-brown-light);"
                  data-es={e.labelEs} data-en={e.labelEn}>{e.labelEs}</span>
                {e.email}
              </a>
            </li>
          ))}
        </ul>

        <!-- WhatsApp Quick Contacts -->
        <div class="space-y-2">
          <a href="https://wa.me/528441227872" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-xs transition-colors duration-200 font-body"
            style="color: var(--steel-400);"
            onmouseover="this.style.color='var(--brick-red-light)'"
            onmouseout="this.style.color='var(--steel-400)'">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Ing. Manuel — 844 122 7872
          </a>
          
          <a href="https://wa.me/528441020928" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-xs transition-colors duration-200 font-body"
            style="color: var(--steel-400);"
            onmouseover="this.style.color='var(--brick-red-light)'"
            onmouseout="this.style.color='var(--steel-400)'">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Ing. Miguel — 844 102 0928
          </a>

          <a href="tel:+528441795365"
            class="flex items-center gap-2 text-xs transition-colors duration-200 font-body"
            style="color: var(--steel-400);"
            onmouseover="this.style.color='var(--sand)'"
            onmouseout="this.style.color='var(--steel-400)'">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Lic. Elia Cuevas — 844 179 5365
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid rgba(140,82,48,0.15);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs font-body" style="color: var(--steel-500);"
        data-es={`© ${currentYear} Rustic Iron Mexico. Todos los derechos reservados.`}
        data-en={`© ${currentYear} Rustic Iron Mexico. All rights reserved.`}>
        © {currentYear} Rustic Iron Mexico. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-1.5 font-body">
        <div class="w-1.5 h-1.5 rounded-full" style="background: var(--brick-red);"></div>
        <p class="text-xs" style="color: var(--steel-500);"
          data-es="Saltillo, Coahuila, México 🇲🇽" data-en="Saltillo, Coahuila, Mexico 🇲🇽">
          Saltillo, Coahuila, México 🇲🇽
        </p>
      </div>
    </div>
  </div>
</footer>
