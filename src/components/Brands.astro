---
// Brands.astro — Showcase of Brands sold and distributed by Rustic Iron Mexico
// Recreates the slide mockup in a premium, modern layout
import TexasStar from './TexasStar.astro';

// We group the brands into two categories based on the client mockup
const comercializadas = [
  {
    name: 'Schmetz',
    logoType: 'img',
    src: '/logos/schmetz.png'
  },
  {
    name: 'Wolff Industries, Inc',
    logoType: 'img',
    src: '/logos/wolff.png'
  },
  {
    name: 'Groz-Beckert',
    logoType: 'img',
    src: '/logos/groz.png',
    style: 'transform: scale(1.4);'
  },
  {
    name: 'Belmont',
    logoType: 'img',
    src: '/logos/belmont.png',
    style: 'transform: scale(1.45);'
  },
  {
    name: 'W.S. Bessett Inc',
    logoType: 'img',
    src: '/logos/bessett.jpeg'
  },
  {
    name: 'Golden Eagle',
    logoType: 'img',
    src: '/logos/goldeneagle.png'
  },
  {
    name: 'Avery Dennison',
    logoType: 'img',
    src: '/logos/avery.png',
    style: 'transform: scale(1.8);'
  },
  {
    name: 'Mitchell Abrasives',
    logoType: 'img',
    src: '/logos/mitchell.png',
    style: 'transform: scale(2.9);'
  }
];

const distribucion = [
  {
    name: 'Organ Needles',
    labelEs: 'Agujas Industriales',
    labelEn: 'Industrial Needles',
    logoType: 'img',
    src: '/logos/needles.png'
  },
  {
    name: 'Dürkopp Adler',
    labelEs: 'Maquinaria Alemana Pesada',
    labelEn: 'German Heavy Machinery',
    logoType: 'img',
    src: '/logos/durkopp.png'
  }
];
---

<section id="marcas" class="relative py-24 md:py-32 overflow-hidden"
  style="background: linear-gradient(180deg, var(--parchment-light) 0%, var(--parchment) 100%); border-top: 1px solid rgba(140,82,48,0.12);">

  <!-- Mesh decorative background glows -->
  <div class="mesh-bloom"
    style="width: 550px; height: 550px; top: 10%; left: -8%; background: radial-gradient(circle, rgba(140,82,48,0.04) 0%, transparent 70%);"></div>
  <div class="mesh-bloom"
    style="width: 500px; height: 500px; bottom: 5%; right: -5%; background: radial-gradient(circle, rgba(178,63,47,0.03) 0%, transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- ── Title Block ── -->
    <div class="text-center mb-20 reveal">
      <span class="section-label mb-5 inline-flex">
        <TexasStar class="text-brick-red-light" size="w-4 h-4" />
        <span data-es="Marcas Premium" data-en="Premium Brands">Marcas Premium</span>
      </span>
      <h2 class="section-title mt-4 mb-6"
        data-es="Respaldo de marcas<br/><span class='gradient-text-gold'>líderes a nivel mundial</span>"
        data-en="Backed by<br/><span class='gradient-text-gold'>world-leading brands</span>">
        Respaldo de marcas<br/>
        <span class="gradient-text-gold">líderes a nivel mundial</span>
      </h2>
      <p class="text-lg max-w-2xl mx-auto font-body" style="color: var(--iron-700);"
        data-es="Proveemos insumos y equipos industriales de fabricantes prestigiosos para garantizar el máximo rendimiento y durabilidad en sus operaciones textiles."
        data-en="We provide industrial supplies and machinery from prestigious manufacturers to guarantee maximum performance and durability in your textile operations.">
        Proveemos insumos y equipos industriales de fabricantes prestigiosos para garantizar el máximo rendimiento y durabilidad en sus operaciones textiles.
      </p>
    </div>

    <!-- ── Dual Column Brand Showcase Layout ── -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">

      <!-- Column 1: Marcas Comercializadas (Grid) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="flex items-center gap-4 mb-2 reveal">
          <TexasStar class="text-saddle-brown" size="w-4 h-4" />
          <h3 class="text-2xl font-bold uppercase tracking-wider font-subtitle" style="color: var(--saddle-brown-dark);"
            data-es="Marcas Comercializadas" data-en="Commercialized Brands">
            Marcas Comercializadas
          </h3>
          <div class="h-px flex-1" style="background: linear-gradient(90deg, rgba(140,82,48,0.25), transparent);"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {comercializadas.map((brand, i) => (
            <div
              class="brand-card group relative flex items-center justify-center p-4 rounded-xl leather-card reveal"
              style={`transition-delay: ${i * 40}ms; min-height: 85px;`}
            >
              <!-- Tactile grain overlay -->
              <div class="grain-overlay"></div>

              <!-- Logo render -->
              {brand.logoType === 'img' ? (
                <div class="w-full flex items-center justify-center transition-all duration-300 group-hover:scale-106 select-none" style="height: 48px;">
                  <img src={brand.src} alt={brand.name} class="max-w-full max-h-full object-contain" style={brand.style || ''} />
                </div>
              ) : (
                <div class="w-full flex items-center justify-center transition-all duration-300 group-hover:scale-106 select-none"
                  style="height: 48px;"
                  set:html={brand.svg}
                />
              )}

              <!-- Colored border overlay on hover -->
              <div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
                style="box-shadow: inset 0 0 0 1px rgba(140,82,48,0.3), 0 6px 20px rgba(140,82,48,0.08);"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- Column 2: Marcas con Distribución (Premium Highlights) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="flex items-center gap-4 mb-2 reveal">
          <TexasStar class="text-brick-red" size="w-4 h-4" />
          <h3 class="text-2xl font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);"
            data-es="Distribución Autorizada" data-en="Authorized Distribution">
            Distribución Autorizada
          </h3>
          <div class="h-px flex-1" style="background: linear-gradient(90deg, rgba(178,63,47,0.25), transparent);"></div>
        </div>

        <div class="flex flex-col sm:flex-row lg:flex-col gap-5">
          {distribucion.map((brand, i) => (
            <div
              class="dist-card group relative flex items-center gap-5 p-5 rounded-2xl reveal w-full"
              style={`
                background: linear-gradient(135deg, rgba(255,255,255,0.85) 0%, rgba(250,244,230,0.9) 100%);
                border: 1px solid rgba(178,63,47,0.22);
                box-shadow: inset 0 0 10px rgba(255,255,255,0.5), 0 10px 30px rgba(86,48,26,0.07);
                transition-delay: ${(i + 1) * 100}ms;
              `}
            >
              <!-- Tactile grain overlay -->
              <div class="grain-overlay"></div>

              <!-- Top right distributor ribbon -->
              <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[9px] font-bold uppercase tracking-wider font-subtitle"
                style="background: rgba(178,63,47,0.1); color: var(--brick-red-light); border: 1px solid rgba(178,63,47,0.18);">
                <TexasStar class="text-brick-red-light animate-spin-slow" size="w-2 h-2" />
                <span data-es="Distribuidor" data-en="Distributor">Distribuidor</span>
              </div>

              <!-- Brand Logo Area -->
              <div class="flex-shrink-0 flex items-center justify-center p-2 bg-white/40 rounded-xl border border-saddle-brown/5 shadow-inner transition-all duration-400 group-hover:scale-105"
                style="width: 90px; height: 90px;">
                {brand.logoType === 'svg' ? (
                  <div class="w-full h-full flex items-center justify-center" set:html={brand.svg} />
                ) : (
                  <img src={brand.src} alt={brand.name} class="w-full h-auto max-h-16 object-contain" />
                )}
              </div>

              <!-- Content Description Area -->
              <div class="flex-grow">
                <h4 class="text-lg font-bold font-title leading-tight" style="color: var(--iron-950);">{brand.name}</h4>
                <p class="text-xs font-semibold uppercase tracking-wider mt-1.5 font-subtitle" style="color: var(--brick-red-light);"
                  data-es={brand.labelEs} data-en={brand.labelEn}>
                  {brand.labelEs}
                </p>
                <p class="text-xs font-body leading-relaxed mt-2" style="color: var(--iron-600);"
                  data-es="Distribución oficial con soporte técnico."
                  data-en="Official distribution with direct plant technical support.">
                  Distribución oficial con soporte técnico.
                </p>
              </div>

              <!-- Animated borders on hover -->
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none"
                style="box-shadow: inset 0 0 0 1.5px var(--brick-red-light), 0 12px 35px rgba(178,63,47,0.15);"></div>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* Keep original colors with soft opacity transition */
  .brand-card img, .brand-card svg {
    width: 100%;
    height: 100%;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }
  .brand-card:hover img, .brand-card:hover svg {
    opacity: 1;
  }

  .dist-card img, .dist-card svg {
    opacity: 0.95;
    transition: opacity 0.4s ease;
  }
  .dist-card:hover img, .dist-card:hover svg {
    opacity: 1;
  }

  /* Dist card dynamic hover motion */
  .dist-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .dist-card:hover {
    transform: translateY(-4px) scale(1.015);
    border-color: rgba(178,63,47,0.45) !important;
  }

  /* Brand card motion */
  .brand-card {
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .brand-card:hover {
    transform: translateY(-3px);
    border-color: rgba(140,82,48,0.4) !important;
  }
</style>
