---
// About.astro — Redesigned "Nosotros" Section based on slide mockup
import TexasStar from './TexasStar.astro';
---

<section id="nosotros" class="relative py-24 md:py-32 overflow-hidden"
  style="background: linear-gradient(160deg, var(--parchment) 0%, var(--parchment-light) 60%, var(--parchment) 100%);">

  <!-- Deco blooms -->
  <div class="mesh-bloom"
    style="width:600px; height:600px; top:-10%; left:-15%; background: radial-gradient(circle, rgba(140,82,48,0.05) 0%, transparent 70%);"></div>

  <!-- Top wave -->
  <div class="wave-top" style="margin-top: -1px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:80px;">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,0 L0,0 Z" fill="var(--parchment-light)"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Title: NOSOTROS -->
    <div class="text-center mb-16">
      <span class="section-label mb-4 reveal inline-flex">
        <TexasStar class="text-brick-red-light" size="w-4 h-4" />
        <span data-es="Quiénes Somos" data-en="Who We Are">Quiénes Somos</span>
      </span>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wider mt-4 mb-6 reveal font-title"
        style="color: var(--iron-950);"
        data-es="Nosotros" data-en="About Us">
        Nosotros
      </h2>
      
      <p class="text-lg md:text-xl leading-relaxed max-w-4xl mx-auto reveal font-body" 
        style="color: var(--iron-700); transition-delay:80ms;"
        data-es="Somos una empresa 100% mexicana que proveemos productos de las mejores marcas de renombre mundial de las cuales algunas contamos con la distribución, con el fin de incrementar la productividad generando ahorros en sus procesos productivos."
        data-en="We are a 100% Mexican company providing products from the best world-renowned brands, some of which we distribute, in order to increase productivity by generating savings in your production processes.">
        Somos una empresa 100% mexicana que proveemos productos de las mejores marcas de renombre mundial de las cuales algunas contamos con la distribución, con el fin de incrementar la productividad generando ahorros en sus procesos productivos.
      </p>
    </div>

    <!-- Misión, Visión, Valores Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
      
      <!-- Left Column: Misión + Image (Spans 6 cols) -->
      <div class="md:col-span-6 flex flex-col gap-8">
        
        <!-- Misión Card -->
        <div class="parchment-card p-6 md:p-8 reveal-left shadow-lg" style="transition-delay:160ms;">
          <div class="flex items-center gap-3 mb-4">
            <TexasStar class="text-brick-red" size="w-5 h-5" />
            <h3 class="text-xl font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);" data-es="Misión" data-en="Mission">Misión</h3>
          </div>
          <p class="text-base md:text-lg leading-relaxed font-body" style="color: #4a3425;"
            data-es="Ser una comercializadora confiable que a través del mejor servicio seamos su mejor opción de compra."
            data-en="To be a reliable trading company that through the best service becomes your best purchasing option.">
            Ser una comercializadora confiable que a través del mejor servicio seamos su mejor opción de compra.
          </p>
        </div>

        <!-- Hanging Signs Image (as in slide) -->
        <div class="reveal-left rounded-3xl overflow-hidden shadow-xl border border-saddle-brown/10 hover:scale-102 transition-transform duration-500 max-w-md mx-auto md:mx-0 w-full" 
          style="transition-delay:240ms;">
          <img 
            src="/images/mision_vision.png" 
            alt="Misión, Visión, Valores" 
            class="w-full h-auto object-cover"
          />
        </div>
      </div>

      <!-- Right Column: Visión + Valores (Spans 6 cols) -->
      <div class="md:col-span-6 flex flex-col gap-8">
        
        <!-- Visión Card -->
        <div class="parchment-card p-6 md:p-8 reveal-right shadow-lg" style="transition-delay:200ms;">
          <div class="flex items-center gap-3 mb-4">
            <TexasStar class="text-brick-red" size="w-5 h-5" />
            <h3 class="text-xl font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);" data-es="Visión" data-en="Vision">Visión</h3>
          </div>
          <p class="text-base md:text-lg leading-relaxed font-body" style="color: #4a3425;"
            data-es="Alcanzar la primera posición entre las empresas distribuidoras del género."
            data-en="To reach the first position among distributing companies of this industry.">
            Alcanzar la primera posición entre las empresas distribuidoras del género.
          </p>
        </div>

        <!-- Valores Card -->
        <div class="parchment-card p-6 md:p-8 reveal-right shadow-lg" style="transition-delay:280ms;">
          <div class="flex items-center gap-3 mb-4">
            <TexasStar class="text-brick-red" size="w-5 h-5" />
            <h3 class="text-xl font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);" data-es="Valores" data-en="Values">Valores</h3>
          </div>
          <p class="text-base md:text-lg leading-relaxed font-body" style="color: #4a3425;"
            data-es="Bajo los principios de transparencia, honestidad y vocación de servicio."
            data-en="Under the principles of transparency, honesty, and dedication to service.">
            Bajo los principios de transparencia, honestidad y vocación de servicio.
          </p>
        </div>
      </div>

    </div>

    <!-- Small Footer-like info row as in mockup -->
    <div class="mt-16 pt-8 border-t border-saddle-brown/10 flex flex-wrap justify-between items-center gap-4 text-xs font-subtitle uppercase tracking-widest text-iron-500 reveal" style="transition-delay:320ms;">
      <span data-es="Rustic Iron Mexico.com" data-en="Rustic Iron Mexico.com">Rustic Iron Mexico.com</span>
      <span class="lowercase">ventas@rusticironmexico.com</span>
    </div>

  </div>

  <!-- Bottom wave -->
  <div class="wave-bottom" style="margin-top: 60px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:80px;">
      <path d="M0,40 C360,0 720,80 1080,40 C1260,20 1380,60 1440,40 L1440,80 L0,80 Z" fill="var(--parchment-light)"/>
    </svg>
  </div>
</section>

<script>
  const revealEls = document.querySelectorAll('.reveal-left, .reveal-right, .reveal-scale, .reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.07 });
  revealEls.forEach(el => observer.observe(el));
</script>
