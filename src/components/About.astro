---
// About.astro — Mission/Vision/Values + Stats + Visual
import TexasStar from './TexasStar.astro';

const values = [
  {
    icon: '🔍',
    titleEs: 'Transparencia',
    titleEn: 'Transparency',
    descEs: 'Operamos con total claridad en cada transacción y proceso comercial.',
    descEn: 'We operate with total clarity in every transaction and business process.',
  },
  {
    icon: '🤝',
    titleEs: 'Honestidad',
    titleEn: 'Honesty',
    descEs: 'Construimos relaciones duraderas basadas en la confianza mutua.',
    descEn: 'We build long-lasting relationships based on mutual trust.',
  },
  {
    icon: '🎯',
    titleEs: 'Vocación de Servicio',
    titleEn: 'Service Vocation',
    descEs: 'El mejor servicio es nuestro diferenciador principal en el mercado.',
    descEn: 'The best service is our main differentiator in the market.',
  },
];

const stats = [
  { num: '21+', labelEs: 'Empresas atendidas', labelEn: 'Companies served' },
  { num: '10+', labelEs: 'Categorías de producto', labelEn: 'Product categories' },
  { num: '6+',  labelEs: 'Marcas exclusivas', labelEn: 'Exclusive brands' },
  { num: '∞',   labelEs: 'Stock disponible', labelEn: 'Available stock' },
];
---

<section id="nosotros" class="relative py-24 md:py-32 overflow-hidden"
  style="background: linear-gradient(160deg, var(--iron-900) 0%, var(--iron-850) 60%, var(--iron-900) 100%);">

  <!-- Deco -->
  <div class="mesh-bloom"
    style="width:600px; height:600px; top:-10%; left:-15%; background: radial-gradient(circle, rgba(140,82,48,0.1) 0%, transparent 70%);"></div>

  <!-- Top wave -->
  <div class="wave-top" style="margin-top: -1px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:80px;">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,0 L0,0 Z" fill="#0a0909"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- LEFT — Text Content -->
      <div>
        <span class="section-label mb-6 reveal-left">
          <TexasStar class="text-brick-red-light" size="w-4 h-4" />
          <span data-es="Quiénes Somos" data-en="Who We Are">Quiénes Somos</span>
        </span>

        <h2 class="section-title mt-5 mb-6 reveal-left" style="transition-delay:80ms;"
          data-es="Una empresa mexicana<br/><span class='gradient-text-gold'>con visión global</span>"
          data-en="A Mexican company<br/><span class='gradient-text-gold'>with a global vision</span>">
          Una empresa mexicana<br/>
          <span class="gradient-text-gold">con visión global</span>
        </h2>

        <p class="text-base leading-relaxed mb-8 reveal-left font-body" style="color: var(--steel-400); transition-delay:160ms;"
          data-es="<strong style='color:var(--sand);'>Rustic Iron Mexico</strong> es una empresa 100% mexicana dedicada a la comercialización y distribución de productos para la industria textil. Proveemos las mejores marcas de renombre mundial, de algunas de las cuales tenemos <strong style='color:var(--brick-red-light);'>distribución exclusiva</strong>, con el fin de incrementar la productividad y generar ahorros reales en los procesos productivos."
          data-en="<strong style='color:var(--sand);'>Rustic Iron Mexico</strong> is a 100% Mexican company dedicated to the commercialization and distribution of products for the textile industry. We provide the best world-renowned brands, for some of which we have <strong style='color:var(--brick-red-light);'>exclusive distribution</strong>, in order to increase productivity and generate real savings in production processes.">
          <strong style="color:var(--sand);">Rustic Iron Mexico</strong> es una empresa 100% mexicana dedicada
          a la comercialización y distribución de productos para la industria textil. Proveemos
          las mejores marcas de renombre mundial, de algunas de las cuales tenemos
          <strong style="color:var(--brick-red-light);">distribución exclusiva</strong>, con el fin de
          incrementar la productividad y generar ahorros reales en los procesos productivos.
        </p>

        <!-- Mission/Vision Cards (Parchment Finish) -->
        <div class="grid sm:grid-cols-2 gap-4 mb-10">
          <div class="parchment-card p-5 reveal-left" style="transition-delay:240ms;">
            <div class="flex items-center gap-2 mb-3">
              <TexasStar class="text-brick-red" size="w-5 h-5" />
              <h3 class="text-sm font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);" data-es="Misión" data-en="Mission">Misión</h3>
            </div>
            <p class="text-sm leading-relaxed font-body" style="color: #4a3425;"
              data-es="Ser una comercializadora confiable que, a través del mejor servicio, seamos su mejor opción de compra."
              data-en="To be a reliable commercial distributor that, through the best service, becomes your best purchasing option.">
              Ser una comercializadora confiable que, a través del mejor servicio, seamos su mejor opción de compra.
            </p>
          </div>
          
          <div class="parchment-card p-5 reveal-left" style="transition-delay:320ms;">
            <div class="flex items-center gap-2 mb-3">
              <TexasStar class="text-brick-red" size="w-5 h-5" />
              <h3 class="text-sm font-bold uppercase tracking-wider font-subtitle" style="color: var(--brick-red-dark);" data-es="Visión" data-en="Vision">Visión</h3>
            </div>
            <p class="text-sm leading-relaxed font-body" style="color: #4a3425;"
              data-es="Alcanzar la primera posición entre las empresas distribuidoras del género en México."
              data-en="To achieve the top position among distributing companies of this industry in Mexico.">
              Alcanzar la primera posición entre las empresas distribuidoras del género en México.
            </p>
          </div>
        </div>

        <!-- Values -->
        <div class="space-y-3">
          {values.map((v, i) => (
            <div class="flex items-start gap-4 reveal-left" style={`transition-delay: ${400 + i*80}ms;`}>
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg flex-shrink-0 mt-0.5"
                style="background: rgba(143,45,30,0.12); border: 1px solid rgba(143,45,30,0.35); color: var(--brick-red-light);">
                {v.icon}
              </div>
              <div>
                <h4 class="text-base font-bold mb-1" style="color: var(--steel-100); font-family: var(--font-title);"
                  data-es={v.titleEs} data-en={v.titleEn}>{v.titleEs}</h4>
                <p class="text-sm font-body" style="color: var(--steel-500);"
                  data-es={v.descEs} data-en={v.descEn}>{v.descEs}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT — Visual Stats Bento -->
      <div class="reveal-right flex flex-col gap-5">

        <!-- Main visual card (leather-card) -->
        <div class="relative rounded-3xl overflow-hidden p-8 leather-card"
          style="min-height: 280px;">
          <!-- Grain texture overlay -->
          <div class="grain-overlay"></div>
          
          <!-- Decorative rings -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full opacity-[0.05] animate-spin-slow"
            style="border: 2px dashed var(--saddle-brown-light);"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-44 h-44 rounded-full opacity-[0.08] animate-spin-slow"
            style="border: 1px solid var(--saddle-brown-light); animation-direction: reverse; animation-duration: 12s;"></div>

          <!-- Real logo emblem -->
          <div class="relative z-10 flex flex-col items-center justify-center h-full text-center py-8">
            <div class="relative mb-5">
              <!-- Forge glow behind logo -->
              <div class="absolute inset-0 blur-xl scale-150 opacity-30 rounded-full pointer-events-none"
                style="background: radial-gradient(circle, var(--brick-red) 0%, transparent 70%);"></div>
              <img
                src="/images/24.png"
                alt="Rustic Iron Mexico"
                class="relative z-10 transition-transform duration-500 hover:scale-105"
                style="
                  height: 80px;
                  width: auto;
                  max-width: 220px;
                  filter: invert(1) brightness(1.05) drop-shadow(0 0 16px rgba(178,63,47,0.45));
                "
              />
            </div>
            <p class="text-xs mt-1 uppercase tracking-widest font-subtitle" style="color: var(--steel-500);"
              data-es="Distribución Textil Industrial" data-en="Industrial Textile Distribution">Distribución Textil Industrial</p>

            <!-- Location badge -->
            <div class="mt-4 flex items-center gap-2 px-4 py-2 rounded-full text-xs font-subtitle tracking-wider"
              style="background: rgba(140,82,48,0.12); border: 1px solid rgba(140,82,48,0.3); color: var(--sand);">
              <svg class="w-3 h-3 text-brick-red-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span data-es="Saltillo, Coahuila, México" data-en="Saltillo, Coahuila, Mexico">Saltillo, Coahuila, México</span>
            </div>
          </div>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {stats.map((s, i) => (
            <div class="leather-card p-5 text-center reveal-scale" style={`transition-delay: ${i*80}ms;`}>
              <div class="grain-overlay"></div>
              <p class="text-3xl font-bold mb-1" style="color: var(--brick-red-light); font-family: var(--font-title);">{s.num}</p>
              <p class="text-xs font-bold uppercase tracking-widest font-subtitle" style="color: var(--sand);"
                data-es={s.labelEs} data-en={s.labelEn}>{s.labelEs}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="wave-bottom" style="margin-top: 60px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:80px;">
      <path d="M0,40 C360,0 720,80 1080,40 C1260,20 1380,60 1440,40 L1440,80 L0,80 Z" fill="#0a0909"/>
    </svg>
  </div>
</section>

<script>
  const revealEls = document.querySelectorAll('.reveal-left, .reveal-right, .reveal-scale, .reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.07 });
  revealEls.forEach(el => observer.observe(el));
</script>
