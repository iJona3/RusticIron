---

<section id="clientes" class="relative py-24 md:py-32 overflow-hidden"
  style="background: linear-gradient(180deg, var(--parchment-light) 0%, var(--parchment) 100%);">

  <div class="mesh-bloom"
    style="width:600px;height:600px;bottom:-10%;left:-10%;background:radial-gradient(circle,rgba(140,82,48,0.04) 0%,transparent 70%);"></div>
  <div class="mesh-bloom"
    style="width:400px;height:400px;top:10%;right:-8%;background:radial-gradient(circle,rgba(178,63,47,0.03) 0%,transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ── Header ── -->
    <div class="text-center mb-16 reveal">
      <span class="section-label mb-5">
        <TexasStar class="text-brick-red-light" size="w-4 h-4" />
        <span data-es="Clientes Destacados" data-en="Featured Clients">Clientes Destacados</span>
      </span>
      <h2 class="section-title mt-4 mb-5"
        data-es="Confían en nosotros<br/><span class='gradient-text-gold'>líderes de la industria</span>"
        data-en="Trusted by<br/><span class='gradient-text-gold'>industry leaders</span>">
        Confían en nosotros<br/>
        <span class="gradient-text-gold">líderes de la industria</span>
      </h2>
      <p class="text-lg max-w-2xl mx-auto font-body" style="color:var(--iron-700);"
        data-es="Más de <strong style='color:var(--iron-950);'>21 empresas de nivel mundial</strong> nos eligen como su proveedor preferente de insumos textiles industriales."
        data-en="More than <strong style='color:var(--iron-950);'>21 world-class companies</strong> choose us as their preferred supplier of industrial textile supplies.">
        Más de <strong style="color:var(--iron-950);">21 empresas de nivel mundial</strong> nos eligen como
        su proveedor preferente de insumos textiles industriales.
      </p>
    </div>

    <!-- ── Logo Grid ── -->
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7 gap-3 md:gap-4">
      {clients.map((client, i) => {
        const industryColor = industryColors[client.industry] || 'var(--brick-red-light)';
        return (
          <div
            class="client-logo-card group relative flex flex-col items-center justify-between gap-3 p-4 rounded-2xl leather-card reveal"
            style={`
              transition-delay:${(i % 7) * 40}ms;
              min-height: 125px;
            `}
          >
            <!-- Grain texture overlay -->
            <div class="grain-overlay"></div>

            <!-- SVG Logo area -->
            <div class="w-full flex items-center justify-center transition-all duration-400 group-hover:scale-105"
              style="height: 52px;"
              set:html={client.svg}
            />

            <!-- Client name -->
            <p class="text-center text-xs font-semibold leading-tight w-full mt-1" style="color: var(--iron-800); font-family: system-ui, -apple-system, sans-serif;">
              {client.name}
            </p>

            <!-- Industry tag -->
            <span class="text-[9px] font-bold tracking-wider uppercase px-2.5 py-1 rounded-full font-subtitle"
              style={`background:${industryColor}12; color:${industryColor}; border:1px solid ${industryColor}25;`}
              data-es={industryTranslations[client.industry]?.es || client.industry}
              data-en={industryTranslations[client.industry]?.en || client.industry}>
              {industryTranslations[client.industry]?.es || client.industry}
            </span>

            <!-- Hover border glow -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none"
              style="box-shadow: inset 0 0 0 1px rgba(140,82,48,0.35), 0 8px 30px rgba(140,82,48,0.1);"></div>
          </div>
        );
      })}
    </div>

    <!-- ── Summary Stats ── -->
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-14 reveal">
      {[
        { num: '21+', labelEs: 'Empresas atendidas', labelEn: 'Companies served' },
        { num: '100%', labelEs: 'Empresa mexicana', labelEn: 'Mexican company' },
        { num: '10+', labelEs: 'Años de experiencia', labelEn: 'Years of experience' },
        { num: '∞',   labelEs: 'Stock disponible', labelEn: 'Available stock' },
      ].map(s => (
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold font-title" style="color:var(--brick-red-light);">{s.num}</p>
          <p class="text-xs tracking-widest uppercase mt-1 font-subtitle" style="color:var(--iron-600);"
            data-es={s.labelEs} data-en={s.labelEn}>{s.labelEs}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* SVG logos: silhouetted dark by default, color on hover */
  .client-logo-card svg {
    width: 100%;
    height: 100%;
    max-height: 52px;
    filter: grayscale(1) brightness(0.2) opacity(0.4);
    transition: filter 0.35s ease, opacity 0.35s ease;
  }
  .client-logo-card:hover svg {
    filter: none;
    opacity: 1;
  }
  .client-logo-card {
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                border-color 0.35s ease,
                background 0.35s ease;
  }
  .client-logo-card:hover {
    transform: translateY(-5px) scale(1.04);
    background: linear-gradient(145deg, var(--parchment-light), var(--parchment)) !important;
    border-color: rgba(140,82,48,0.45) !important;
  }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
  }, { threshold: 0.05 });
  revealEls.forEach(el => obs.observe(el));
</script>
