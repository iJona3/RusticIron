---
// Navbar.astro — Floating Pill Glassmorphism Navigation with Language Switcher
---

<header id="nav-wrapper" class="fixed top-4 left-0 w-full z-50 flex justify-center px-4" style="box-sizing: border-box;">
  <nav id="navbar" class="flex items-center justify-between w-full max-w-5xl px-5 py-3 rounded-full transition-all duration-500"
    style="
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(140, 82, 48, 0.22);
      box-shadow: 0 8px 32px rgba(86, 48, 26, 0.08), 0 0 0 1px rgba(255,255,255,0.8);
      box-sizing: border-box;
    ">

    <!-- Logo / Brand -->
    <a href="#hero" class="flex items-center flex-shrink-0 group" id="brand-logo"
      aria-label="Rustic Iron Mexico — Inicio">
      <img
        src="/logo2.png"
        alt="Rustic Iron Mexico"
        class="transition-all duration-300 group-hover:scale-105 h-12 md:h-16 w-auto"
        style="
          max-width: 220px;
          filter: drop-shadow(0 2px 8px rgba(86, 48, 26, 0.1));
          flex-shrink: 0;
        "
      />
    </a>

    <!-- Desktop Links -->
    <ul id="nav-links" class="hidden md:flex items-center gap-1">
      {[
        { href: '#hero',              labelEs: 'Inicio',    labelEn: 'Home' },
        { href: '#productos',         labelEs: 'Productos', labelEn: 'Products' },
        { href: '#nosotros',          labelEs: 'Nosotros',  labelEn: 'About Us' },
        { href: '#contacto',          labelEs: 'Contacto',  labelEn: 'Contact' },
      ].map(item => (
        <li>
          <a href={item.href}
            class="nav-link relative px-4 py-2 text-lg font-bold tracking-widest transition-all duration-300 rounded-full"
            style="color: var(--steel-200); font-family: var(--font-subtitle);"
            data-es={item.labelEs}
            data-en={item.labelEn}>
            {item.labelEs}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA & Lang Switcher Desktop -->
    <div class="hidden md:flex items-center gap-3">
      <!-- Language Toggle Button -->
      <button class="flex items-center gap-1.5 px-3.5 py-2 rounded-full border border-saddle-brown/30 bg-white/40 text-xs font-bold font-subtitle tracking-wider text-saddle-brown-dark hover:border-brick-red hover:text-brick-red transition-all cursor-pointer select-none lang-toggle-btn">
        🌐 <span class="lang-label">EN</span>
      </button>

      <!-- WhatsApp Button -->
      <a href="https://wa.me/528441020928?text=Hola%2C%20me%20interesa%20un%20producto" target="_blank" rel="noopener noreferrer"
        class="btn-gold text-xs px-5 py-2.5 gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <!-- Mobile CTA & Menu Trigger -->
    <div class="flex items-center gap-2.5 md:hidden">
      <!-- Language Switcher Mobile -->
      <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-saddle-brown/30 bg-white/40 text-[10px] font-bold font-subtitle tracking-wider text-saddle-brown-dark lang-toggle-btn cursor-pointer select-none">
        🌐 <span class="lang-label">EN</span>
      </button>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="flex flex-col gap-1.5 p-2 rounded-xl transition-all duration-300"
        aria-label="Abrir menú de navegación"
        style="min-width: 44px; min-height: 44px; justify-content: center; align-items: center;">
        <span class="hamburger-line block w-5 h-0.5 rounded-full transition-all duration-300" style="background: var(--iron-900);"></span>
        <span class="hamburger-line block w-5 h-0.5 rounded-full transition-all duration-300" style="background: var(--iron-900);"></span>
        <span class="hamburger-line block w-5 h-0.5 rounded-full transition-all duration-300" style="background: var(--iron-900);"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu"
    class="absolute top-full mt-3 w-[calc(100%-2rem)] max-w-xl rounded-3xl overflow-hidden transition-all duration-500"
    style="
      background: rgba(251, 248, 240, 0.98);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(140, 82, 48, 0.22);
      box-shadow: 0 20px 60px rgba(86, 48, 26, 0.12);
      opacity: 0;
      transform: translateY(-10px) scale(0.98);
      pointer-events: none;
      left: 50%;
      transform: translateX(-50%) translateY(-10px) scale(0.98);
    "
    aria-hidden="true">
    <ul class="flex flex-col p-4 gap-1">
      {[
        { href: '#hero',      labelEs: 'Inicio',    labelEn: 'Home',     icon: '🏠' },
        { href: '#productos', labelEs: 'Productos', labelEn: 'Products', icon: '⚙️' },
        { href: '#nosotros',  labelEs: 'Nosotros',  labelEn: 'About Us', icon: '🏢' },
        { href: '#contacto',  labelEs: 'Contacto',  labelEn: 'Contact',  icon: '📞' },
      ].map(item => (
        <li>
          <a href={item.href}
            class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-2xl text-lg tracking-widest font-bold transition-all duration-200"
            style="color: var(--steel-200); font-family: var(--font-subtitle);">
            <span class="text-lg">{item.icon}</span>
            <span data-es={item.labelEs} data-en={item.labelEn}>{item.labelEs}</span>
          </a>
        </li>
      ))}
      <li class="mt-2 pt-2" style="border-top: 1px solid rgba(255,255,255,0.06);">
        <a href="https://wa.me/528441020928?text=Hola%2C%20me%20interesa%20un%20producto" target="_blank" rel="noopener noreferrer"
          class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-2xl text-base tracking-widest font-bold transition-all duration-200"
          style="background: linear-gradient(135deg, rgba(143, 45, 30, 0.15), rgba(99, 29, 18, 0.08)); color: var(--brick-red-light); border: 1px solid rgba(143, 45, 30, 0.35); font-family: var(--font-subtitle);">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span data-es="Contactar por WhatsApp" data-en="Contact on WhatsApp">Contactar por WhatsApp</span>
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  /* Nav link hover animated underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--saddle-brown), var(--brick-red));
    border-radius: 99px;
    transition: width 0.3s ease;
  }
  .nav-link:hover {
    color: var(--brick-red) !important;
  }
  .nav-link:hover::after {
    width: 60%;
  }

  .mobile-nav-link:hover {
    background: rgba(140, 82, 48, 0.06);
    color: var(--brick-red) !important;
    padding-left: 1.5rem;
  }

  /* Mobile menu open state */
  #mobile-menu.open {
    opacity: 1 !important;
    transform: translateX(-50%) translateY(0) scale(1) !important;
    pointer-events: all !important;
  }

  /* Hamburger X animation */
  #mobile-menu-btn.open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #mobile-menu-btn.open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-menu-btn.open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Scrolled state */
  #nav-wrapper.scrolled #navbar {
    background: rgba(255, 255, 255, 0.92) !important;
    box-shadow: 0 4px 24px rgba(86, 48, 26, 0.1) !important;
  }
</style>

<script>
  // ---- Scroll effect ----
  const navWrapper = document.getElementById('nav-wrapper');
  const navbar     = document.getElementById('navbar');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navWrapper?.classList.add('scrolled');
      navbar?.classList.add('scale-[0.97]');
    } else {
      navWrapper?.classList.remove('scrolled');
      navbar?.classList.remove('scale-[0.97]');
    }
  }, { passive: true });

  // ---- Mobile menu toggle ----
  const mobileBtn  = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  mobileBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      mobileMenu?.classList.remove('open');
      mobileBtn?.classList.remove('open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
    } else {
      mobileMenu?.classList.add('open');
      mobileBtn?.classList.add('open');
      mobileMenu?.setAttribute('aria-hidden', 'false');
    }
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      mobileBtn?.classList.remove('open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
    });
  });

  // ---- i18n click handler ----
  document.querySelectorAll('.lang-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const currentLang = localStorage.getItem('lang') || 'es';
      const newLang = currentLang === 'es' ? 'en' : 'es';
      localStorage.setItem('lang', newLang);
      document.documentElement.lang = newLang;
      
      // Translate all DOM elements with data-es
      document.querySelectorAll('[data-es]').forEach(el => {
        const txt = el.getAttribute(`data-${newLang}`);
        if (txt) {
          if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            (el as HTMLInputElement).placeholder = txt;
          } else {
            el.innerHTML = txt;
          }
        }
      });
      
      // Update toggle labels
      document.querySelectorAll('.lang-label').forEach(lbl => {
        lbl.textContent = newLang === 'es' ? 'EN' : 'ES';
      });
    });
  });
</script>
