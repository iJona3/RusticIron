---
// Hero.astro — Cinematic Hero with Forge Blooms + Texas Stars (Bilingual support)
import TexasStar from './TexasStar.astro';
---

<section id="hero" class="relative min-h-[100svh] flex flex-col justify-center items-center overflow-hidden"
  style="background: linear-gradient(160deg, #0a0909 0%, #151313 50%, #0a0909 100%);">

  <!-- === FORGE / RUST BLOOM BACKGROUND === -->
  <div class="mesh-bloom animate-pulse-glow"
    style="width:700px; height:700px; top:-15%; left:-18%; background: radial-gradient(circle, rgba(178,63,47,0.15) 0%, transparent 70%);"></div>
  <div class="mesh-bloom animate-pulse-glow"
    style="width:600px; height:600px; bottom:-20%; right:-15%; background: radial-gradient(circle, rgba(140,82,48,0.12) 0%, transparent 70%);"></div>
  <div class="mesh-bloom animate-pulse-glow"
    style="width:400px; height:400px; top:40%; left:55%; background: radial-gradient(circle, rgba(222,203,183,0.08) 0%, transparent 70%);"></div>

  <!-- === DECORATIVE GRID === -->
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none"
    style="background-image: linear-gradient(rgba(222,203,183,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(222,203,183,0.15) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- === FLOATING BADGES (desktop) === -->
  <div class="hidden lg:flex absolute top-36 left-12 animate-float" style="animation-delay:0s;">
    <div class="glass-card-gold px-4 py-3 flex items-center gap-2.5 shadow-xl">
      <span class="text-2xl">🇲🇽</span>
      <div>
        <p class="text-xs font-bold uppercase tracking-wider font-subtitle" style="color:var(--sand);" data-es="100% Mexicana" data-en="100% Mexican">100% Mexicana</p>
        <p class="text-[10px]" style="color:var(--steel-400);" data-es="Empresa nacional" data-en="National company">Empresa nacional</p>
      </div>
    </div>
  </div>

  <div class="hidden lg:flex absolute top-48 right-16 animate-float" style="animation-delay:1.8s;">
    <div class="glass-card-gold px-4 py-3 flex items-center gap-2.5 shadow-xl">
      <span class="text-2xl">📦</span>
      <div>
        <p class="text-xs font-bold uppercase tracking-wider font-subtitle" style="color:var(--sand);" data-es="Stock Inmediato" data-en="Immediate Stock">Stock Inmediato</p>
        <p class="text-[10px]" style="color:var(--steel-400);" data-es="Entrega en planta" data-en="Plant delivery">Entrega en planta</p>
      </div>
    </div>
  </div>

  <div class="hidden lg:flex absolute bottom-40 left-16 animate-float" style="animation-delay:3.2s;">
    <div class="glass-card-gold px-4 py-3 flex items-center gap-2.5 shadow-xl">
      <TexasStar class="text-brick-red-light" size="w-6 h-6" />
      <div>
        <p class="text-xs font-bold uppercase tracking-wider font-subtitle" style="color:var(--sand);" data-es="Dist. Exclusiva" data-en="Exclusive Distr.">Dist. Exclusiva</p>
        <p class="text-[10px]" style="color:var(--steel-400);" data-es="Marcas mundiales" data-en="Global brands">Marcas mundiales</p>
      </div>
    </div>
  </div>

  <div class="hidden lg:flex absolute bottom-48 right-24 animate-float" style="animation-delay:0.9s;">
    <div class="glass-card-gold px-4 py-3 flex items-center gap-2.5 shadow-xl">
      <span class="text-2xl">🏭</span>
      <div>
        <p class="text-xs font-bold uppercase tracking-wider font-subtitle" style="color:var(--sand);" data-es="21+ Clientes" data-en="21+ Clients">21+ Clientes</p>
        <p class="text-[10px]" style="color:var(--steel-400);" data-es="Empresas premium" data-en="Premium companies">Empresas premium</p>
      </div>
    </div>
  </div>

  <!-- === MAIN CONTENT === -->
  <div class="relative z-10 text-center px-4 max-w-5xl mx-auto pt-28 pb-12 md:pt-36 md:pb-16">

    <!-- Real Logo — centered hero display -->
    <div class="flex justify-center mb-8 reveal" style="transition-delay: 0ms;">
      <div class="relative">
        <!-- Glow behind logo -->
        <div class="absolute inset-0 blur-3xl scale-150 opacity-25 rounded-full pointer-events-none"
          style="background: radial-gradient(circle, var(--brick-red) 0%, transparent 75%);"></div>
        <img
          src="/images/24.png"
          alt="Rustic Iron Mexico"
          class="relative z-10 transition-all duration-500 hover:scale-105"
          style="
            height: 95px;
            width: auto;
            max-width: 320px;
            filter: invert(1) brightness(1.05) drop-shadow(0 0 24px rgba(178,63,47,0.35));
          "
        />
      </div>
    </div>

    <!-- Label -->
    <div class="flex justify-center mb-6 reveal" style="transition-delay: 60ms;">
      <span class="section-label">
        <TexasStar class="text-brick-red-light" size="w-4 h-4" />
        <span data-es="Industria Textil · Saltillo, Coahuila" data-en="Textile Industry · Saltillo, Coahuila">Industria Textil · Saltillo, Coahuila</span>
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-none mb-6 reveal" 
      style="transition-delay: 120ms; font-family: var(--font-title);"
      data-es="Tu socio estratégico<br class='hidden sm:block' /><span class='gradient-text-gold'>en la industria</span><br class='hidden sm:block' /><span style='color: var(--steel-50);'>textil</span>"
      data-en="Your strategic partner<br class='hidden sm:block' /><span class='gradient-text-gold'>in the textile</span><br class='hidden sm:block' /><span style='color: var(--steel-50);'>industry</span>">
      Tu socio estratégico<br class="hidden sm:block" />
      <span class="gradient-text-gold">en la industria</span><br class="hidden sm:block" />
      <span style="color: var(--steel-50);">textil</span>
    </h1>

    <!-- Sub -->
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 reveal font-body" 
      style="color: var(--steel-400); transition-delay: 240ms; line-height: 1.7;"
      data-es="Comercialización y distribución de productos de las mejores marcas mundiales — <strong style='color: var(--sand-light);'>Organ Needles, Groz-Beckert, Juki, Schmetz, Wolff Industries</strong> — para incrementar tu productividad y generar ahorros reales."
      data-en="Commercialization and distribution of products from top world brands — <strong style='color: var(--sand-light);'>Organ Needles, Groz-Beckert, Juki, Schmetz, Wolff Industries</strong> — to increase your productivity and generate real savings.">
      Comercialización y distribución de productos de las mejores marcas mundiales —
      <strong style="color: var(--sand-light);">Organ Needles, Groz-Beckert, Juki, Schmetz, Wolff Industries</strong> —
      para incrementar tu productividad y generar ahorros reales.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-4 mb-14 reveal" style="transition-delay: 360ms;">
      <a href="#productos" class="btn-gold text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
        <span data-es="Explorar Productos" data-en="Explore Products">Explorar Productos</span>
      </a>
      <a href="https://wa.me/528441227872?text=Hola%2C%20quiero%20más%20información%20sobre%20sus%20productos"
        target="_blank" rel="noopener noreferrer"
        class="btn-outline text-sm">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-es="Contactar por WhatsApp" data-en="Contact on WhatsApp">Contactar por WhatsApp</span>
      </a>
    </div>

    <!-- Mini stats row -->
    <div class="flex flex-wrap justify-center gap-6 md:gap-12 reveal" style="transition-delay: 480ms;">
      {[
        { num: '21+', labelEs: 'Clientes Premium', labelEn: 'Premium Clients' },
        { num: '100%', labelEs: 'Empresa Mexicana', labelEn: 'Mexican Company' },
        { num: '10+', labelEs: 'Categorías de Producto', labelEn: 'Product Categories' },
        { num: '∞',   labelEs: 'Marcas Mundiales', labelEn: 'Global Brands' },
      ].map(stat => (
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold font-title" style="color: var(--brick-red-light);">{stat.num}</p>
          <p class="text-xs tracking-widest uppercase font-subtitle" style="color: var(--sand-dark);" data-es={stat.labelEs} data-en={stat.labelEn}>{stat.labelEs}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- === SCROLL INDICATOR === -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-[10px] tracking-[0.3em] uppercase font-subtitle" style="color: var(--saddle-brown-light);" data-es="Scroll" data-en="Scroll">Scroll</span>
    <div class="w-5 h-8 rounded-full flex items-center justify-center" style="border: 1px solid rgba(222,203,183,0.15);">
      <div class="w-1 h-1.5 rounded-full animate-scroll-bounce" style="background: var(--brick-red-light);"></div>
    </div>
  </div>

  <!-- === BOTTOM GRADIENT FADE === -->
  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, var(--iron-950));"></div>
</section>

<script>
  // Intersection Observer for reveal animations on Hero
  const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => observer.observe(el));
</script>
